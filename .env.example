# Database
DATABASE_URI=mongodb+srv://username:password@cluster.mongodb.net/seri?retryWrites=true&w=majority

# Payload CMS
PAYLOAD_SECRET=change-this-to-a-random-string-minimum-32-characters-long

# Site URL
NEXT_PUBLIC_SERVER_URL=https://seri.net.in
NEXT_PUBLIC_SITE_NAME=SERI

# ISR Revalidation
REVALIDATION_SECRET=change-this-to-another-random-string-minimum-32-chars

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Media storage (host-agnostic)
# Uploaded media is stored on the LOCAL DISK (public/media) by default — this is
# the right choice for a VPS/self-hosted server with a persistent disk.
# Only set BLOB_READ_WRITE_TOKEN when deploying somewhere with an ephemeral
# filesystem (e.g. Vercel): when present, media is stored in Vercel Blob instead.
# Leave it EMPTY for local disk.
BLOB_READ_WRITE_TOKEN=
